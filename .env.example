# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>     # ⚠ SERVER-ONLY — never prefix with NEXT_PUBLIC_
SUPABASE_PROJECT_ID=<project-ref>                   # used for `npm run db:types`

# ── Preview mode ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
PREVIEW_SECRET=<random-32-char-hex>

# ── On-demand revalidation ────────────────────────────────────────────────────
# Set this same value as the Supabase Database Webhook secret header
REVALIDATION_SECRET=<random-32-char-hex>

# ── Sentry ───────────────────────────────────────────────────────────────────
# Found in: sentry.io → Project Settings → SDK Setup → DSN
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_ORG=<sentry-org-slug>
SENTRY_PROJECT=<sentry-project-slug>
SENTRY_AUTH_TOKEN=<sentry-auth-token>               # ⚠ CI/build only — for source map uploads

# ── Clinic admin (/admin) ─────────────────────────────────────────────────────
ADMIN_PASSWORD=
ADMIN_SECRET=

# ── Email (Resend — booking confirmations) ───────────────────────────────────
# See docs/EMAIL_SETUP.md
RESEND_API_KEY=
EMAIL_FROM=Naturally Beautiful <bookings@yourdomain.com.au>
CLINIC_NOTIFICATION_EMAIL=nbskinrejuvenation@gmail.com

# ── Google Calendar (free consultation bookings) ─────────────────────────────
# See docs/GOOGLE_CALENDAR_SETUP.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://nbskinrejuvenation.com.au
# Optional: Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
