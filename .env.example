# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>     # ⚠ SERVER-ONLY — never prefix with NEXT_PUBLIC_
SUPABASE_PROJECT_ID=<project-ref>                   # used for `npm run db:types`

# ── Preview mode ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
PREVIEW_SECRET=<random-32-char-hex>

# ── On-demand revalidation ────────────────────────────────────────────────────
# Set this same value as the Supabase Database Webhook secret header
REVALIDATION_SECRET=<random-32-char-hex>

# ── Sentry ───────────────────────────────────────────────────────────────────
# Found in: sentry.io → Project Settings → SDK Setup → DSN
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_ORG=<sentry-org-slug>
SENTRY_PROJECT=<sentry-project-slug>
SENTRY_AUTH_TOKEN=<sentry-auth-token>               # ⚠ CI/build only — for source map uploads

# ── Clinic admin (/admin) ─────────────────────────────────────────────────────
ADMIN_PASSWORD=
ADMIN_SECRET=

# ── Vercel Cron (hourly consultation reminders, etc.) ─────────────────────────
# Generate with: openssl rand -hex 32 — required on Vercel for /api/cron/* routes
CRON_SECRET=

# ── Client ops (optional) ─────────────────────────────────────────────────────
# Google review link sent when admin marks appointment completed
GOOGLE_REVIEW_URL=https://g.page/r/your-place/review
# Slack incoming webhook for instant new-booking alerts
SLACK_WEBHOOK_URL=
# Australian mobile to SMS when someone books (uses Twilio vars above)
CLINIC_SMS_PHONE=

# ── SMS (Twilio — 24h consultation reminders) ─────────────────────────────────
# See docs/SMS_SETUP.md
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+61400000000

# ── Email (Resend — booking confirmations) ───────────────────────────────────
# See docs/EMAIL_SETUP.md
RESEND_API_KEY=
# Must be quoted when the display name contains spaces:
EMAIL_FROM="Naturally Beautiful <bookings@yourdomain.com.au>"
CLINIC_NOTIFICATION_EMAIL=nbskinrejuvenation@gmail.com

# ── Stripe (paid treatment booking) ───────────────────────────────────────────
# See docs/STRIPE_SETUP.md
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: charge a deposit instead of full price (1–100, default 100)
# STRIPE_DEPOSIT_PERCENT=100

# ── Google Calendar (free consultation bookings) ─────────────────────────────
# See docs/GOOGLE_CALENDAR_SETUP.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# ── Instagram feed (optional — latest posts in site grid) ─────────────────────
# See docs/INSTAGRAM_FEED_SETUP.md — requires Business/Creator account + Meta app
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# ── AI Chatbot (Anthropic) ────────────────────────────────────────────────────
# Sign up at console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── App — public site URL (emails, Stripe, manage links, sitemap, SEO) ─────────
# Use ONE value per environment. Restart dev server after changing.
#
# Local dev:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
#
# Vercel preview / staging:
NEXT_PUBLIC_SITE_URL=https://website-iota-vert-23.vercel.app
#
# Production (switch when going live):
# NEXT_PUBLIC_SITE_URL=https://nbskinrejuvenation.com.au
#
# In Vercel: Project → Settings → Environment Variables
#   - Preview:  website-iota-vert-23.vercel.app (or your preview URL)
#   - Production: nbskinrejuvenation.com.au

# Optional: Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
